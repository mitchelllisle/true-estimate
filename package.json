		"@testing-library/user-event": "^14.6.1",
		"jsdom": "^27.0.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"gh-pages": "^6.3.0"
	},
	"resolutions": {
		"cookie": "^0.7.0"
